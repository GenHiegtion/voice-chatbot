# ===== LLM Provider Configuration =====
# Provider: "openrouter" or "ollama"
LLM_PROVIDER=openrouter

# OpenRouter settings
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4o

# Ollama settings (for future use)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ===== ASR Text Correction =====
# A lighter/cheaper model for post-ASR text correction
CORRECTION_LLM_PROVIDER=openrouter
CORRECTION_MODEL=openai/gpt-4o-mini

# ===== Voice Activity Detection =====
# Enable/disable Silero VAD (filters silence before ASR)
VAD_ENABLED=true

# ===== Model Cache =====
# Where HuggingFace models (ChunkFormer, etc.) are stored
# Default: ~/.cache/huggingface/hub
# Set this if you want models in a specific location
HF_HOME=

# ===== Database (MySQL) =====
# Leave empty if not using database yet
# When ready, fill in and replace mock tools with real queries
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# ===== Server Configuration =====
HOST=0.0.0.0
PORT=8000
